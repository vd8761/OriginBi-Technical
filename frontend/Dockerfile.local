FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --no-audit --no-fund

COPY . .

ENV NEXT_PUBLIC_EXAM_ENGINE_URL=http://localhost:8088
ENV ENGINE_INTERNAL_URL=http://host.docker.internal:8088
EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]

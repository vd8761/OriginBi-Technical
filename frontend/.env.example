# Origin BI Technical — frontend env
# Copy to .env.local and edit. The admin panel will surface a banner if any of
# the *_API_BASE values are missing.

# Go exam-engine (admin coding/exam-package APIs, plugin registry, judge runs)
NEXT_PUBLIC_API_BASE=http://localhost:8088

# NestJS assessment-service (Cognito auth, registration)
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:5000

# Student-facing service (used by the candidate app, optional for admin)
NEXT_PUBLIC_STUDENT_SERVICE_URL=http://localhost:5001

# Origin BI Technical — frontend env
# Copy to .env.local and edit. All NEXT_PUBLIC_* values are inlined into the
# JS bundle at `next build`; rebuild to change them. Never put real secrets in
# NEXT_PUBLIC_* — they ship to the browser.

# ── Core upstream services ─────────────────────────────────────────────────

# Go exam-engine (admin coding/exam-package APIs, plugin registry, judge runs)
NEXT_PUBLIC_EXAM_ENGINE_URL=http://localhost:8088

# NestJS assessment-service (legacy /api/assessment/* routes, aptitude/MCQ/etc.)
NEXT_PUBLIC_ASSESSMENT_SERVICE_URL=http://localhost:5000

# OriginBI auth-service from sibling project (Cognito registration/login)
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:4002

# Student-facing service from sibling project (profile, forgot-password)
NEXT_PUBLIC_STUDENT_SERVICE_URL=http://localhost:4004

# Judge0 sandbox URL (only used by the legacy direct-browser path; production
# routes through exam-engine instead — leave empty in prod)
NEXT_PUBLIC_JUDGE0_URL=http://localhost:2358

# ── AWS Cognito (required if auth flows are enabled) ───────────────────────
NEXT_PUBLIC_COGNITO_REGION=
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=
# Optional — only configured if set
NEXT_PUBLIC_AWS_IDENTITY_POOL_ID=

# ── Optional feature flags ─────────────────────────────────────────────────
# Set to the literal string "false" to bypass Razorpay (sandbox/dev only)
# NEXT_PUBLIC_RAZORPAY=false

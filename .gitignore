# to set.
!.env.example
!.env.*.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/tmp
.gocache/
backend/exam-engine/.gocache/

# build output
dist/
**/dist/
**/.next/
**/build/
**/coverage/

# IDEs and local assistant state
.idea/
.vscode/
.claude/
**/.claude/

# Local logs and generated reports
.logs/
logs/
*.log
eslint-report*.txt
backend/assessment-service/detailed-audit*.json

# Service build binaries
backend/exam-engine/server
backend/tech-assessment-engine/tech-engine

# Local office/archive artifacts
*.doc
*.docx
*.zip
*.7z
*.rar

origin services.bat
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://originbi.example.com/schemas/assessment-fillblank/config.schema.json",
  "title": "assessment.fillblank config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "allowedLanguages": {
      "type": "array",
      "items": { "type": "string", "pattern": "^language\\." },
      "uniqueItems": true
    },
    "partialCredit": {
      "type": "boolean",
      "default": true,
      "description": "When true, each correctly-filled blank earns 1/N of the question's score. When false, all-or-nothing."
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxBlanks":          { "type": "integer", "minimum": 1, "maximum": 20, "default": 10 },
        "maxResponseLength":  { "type": "integer", "minimum": 1, "maximum": 2000, "default": 500 }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://originbi.local/plugins/evaluator-openai/config.schema.json",
  "title": "OpenAI Evaluator Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["model", "credentialRef"],
  "properties": {
    "provider": {
      "type": "string",
      "const": "openai",
      "default": "openai"
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "default": "gpt-4o-mini"
    },
    "credentialRef": {
      "type": "string",
      "pattern": "^secret://",
      "description": "Secret reference, for example secret://openai/default."
    },
    "timeoutSeconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300,
      "default": 60
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2,
      "default": 0
    }
  }
}

    {
      "title": "Valid Parentheses",
      "plugin_slug": "assessment.coding",
      "difficulty": 3,
      "max_score": 20,
      "body": {
        "type": "coding",
        "responseType": "code",
        "title": "Valid Parentheses",
        "section": "Stacks",
        "category": "Stacks",
        "difficulty": "medium",
        "mode": "main",
        "tags": ["stacks", "strings", "classic"],
        "promptFormat": "markdown",
        "prompt": "## Valid Parentheses\n\nGiven a string containing only `()[]{}`, decide whether the brackets are balanced.\n\nPrint `YES` if every opener has a matching closer in the correct order, otherwise `NO`.",
        "inputFormat":  { "kind": "markdown", "content": "A single line containing only the characters `()[]{}`." },
        "outputFormat": { "kind": "markdown", "content": "Either `YES` or `NO`." },
        "constraintsFormat": { "kind": "markdown", "content": "`1 ≤ length ≤ 1000`" },
        "allowedLanguages": ["language.java"],
        "multiFile": true,
        "entryFile": { "language.java": "Solution.java" },
        "starterFiles": {
          "language.java": [
            { "path": "Solution.java", "content": "import java.util.*;\n\npublic class Solution {\n    public static boolean isValid(String s) {\n        Deque<Character> st = new ArrayDeque<>();\n        for (char c : s.toCharArray()) {\n            if (c == '(' || c == '[' || c == '{') st.push(c);\n            else {\n                if (st.isEmpty()) return false;\n                char o = st.pop();\n                if ((o=='(' && c!=')') || (o=='[' && c!=']') || (o=='{' && c!='}')) return false;\n            }\n        }\n        return st.isEmpty();\n    }\n\n    public static void main(String[] args) {\n        Scanner sc = new Scanner(System.in);\n        String s = sc.hasNextLine() ? sc.nextLine() : \"\";\n        System.out.println(isValid(s) ? \"YES\" : \"NO\");\n    }\n}\n" },
            { "path": "README.md",     "content": "Edit `Solution.java`. Do not rename the class.\n", "readOnly": true }
          ]
        },
        "hintsEnabled": true,
        "hints": [
          { "afterFailures": 2, "text": "A stack is your friend — push opens, pop on closes." },
          { "afterFailures": 4, "text": "On every close, the popped opener must match the close's pair." }
        ]
      },
      "test_cases": [
        { "name": "balanced", "is_sample": true,  "is_hidden": false, "weight": 1, "stdin": "()[]{}",  "expected_stdout": "YES", "explanation": "All openers have an immediate match.", "comparator": "trim_equal" },
        { "name": "crossed",  "is_sample": false, "is_hidden": true,  "weight": 1, "stdin": "([)]",    "expected_stdout": "NO",  "explanation": "Pairs cross; not balanced.",          "comparator": "trim_equal" },
        { "name": "nested",   "is_sample": false, "is_hidden": true,  "weight": 1, "stdin": "{[()]}",  "expected_stdout": "YES", "explanation": "Nested correctly.",                   "comparator": "trim_equal" }
      ]
    },

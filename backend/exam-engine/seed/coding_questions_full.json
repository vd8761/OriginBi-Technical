        "difficulty": "hard",
        "mode": "main",
        "tags": ["design", "cache", "hashmap", "linked-list"],
        "promptFormat": "markdown",
        "prompt": "## LRU Cache\n\nSimulate a Least-Recently-Used cache of fixed capacity.\n\nLine 1: `c q`. Next `q` lines are either `PUT k v` or `GET k`. For each `GET`, print the value, or `-1` if the key is absent.",
        "inputFormat":  { "kind": "plain", "content": "Line 1: c q\nNext q lines: PUT k v | GET k" },
        "outputFormat": { "kind": "plain", "content": "One line per GET — the value or -1." },
        "constraintsFormat": { "kind": "markdown", "content": "`1 ≤ c ≤ 1000, 1 ≤ q ≤ 10^4`" },
        "allowedLanguages": ["language.cpp"],
        "multiFile": true,
        "entryFile": { "language.cpp": "solution.cpp" },
        "starterFiles": {
          "language.cpp": [
            { "path": "solution.cpp", "content": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n    int c, q;\n    if (!(cin >> c >> q)) return 0;\n    // TODO: build LRU(c) and process q ops.\n    return 0;\n}\n" },
            { "path": "lru.hpp",      "content": "// Optional helper header.\n#pragma once\n" }
          ]
        },
        "hintsEnabled": true,
        "hints": [
          { "afterFailures": 3, "text": "Touching a key (GET or PUT) makes it most-recent." },
          { "afterFailures": 6, "text": "A hash map keyed by k plus a doubly-linked list gives O(1) per op." }
        ]
      },
      "test_cases": [
        { "name": "sample", "is_sample": true,  "is_hidden": false, "weight": 1, "stdin": "2 4\nPUT 1 10\nPUT 2 20\nGET 1\nGET 3",       "expected_stdout": "10\n-1", "explanation": "1 hit, 3 miss.",       "comparator": "trim_equal" },
        { "name": "evict",  "is_sample": false, "is_hidden": true,  "weight": 1, "stdin": "2 5\nPUT 1 1\nPUT 2 2\nPUT 3 3\nGET 1\nGET 3", "expected_stdout": "-1\n3", "explanation": "Putting 3 evicts 1 (LRU).", "comparator": "trim_equal" }
      ]
    }
  ]

# Copy to .env.local and edit. Postgres runs natively on host (NOT in Docker).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/obidatanew?sslmode=disable
HTTP_ADDR=:8088
ALLOWED_ORIGINS=http://localhost:3000
JUDGE0_URL=http://localhost:2358
LOG_LEVEL=info
RUN_MIGRATIONS=true
ENSURE_PARTITIONS_ON_BOOT=true
BOOTSTRAP_ADMIN_TOKEN=change-this-before-use
APP_ENV=development
